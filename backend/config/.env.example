# 后端环境变量示例
# 复制为 .env 后使用；请勿把真实 .env 提交到仓库

# 应用
APP_NAME=login-backend
APP_ENV=dev
API_V1_PREFIX=/api/v1

# 服务监听（部署时可覆盖，切勿硬编码地址到代码/前端）
HOST=0.0.0.0
PORT=8000

# 安全
# 生产环境请使用强随机字符串（例如 openssl rand -hex 32）
SECRET_KEY=please-change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# refresh_token cookie 名与安全属性；HTTPS 部署时 COOKIE_SECURE 设为 true
REFRESH_COOKIE_NAME=refresh_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# 登录限流（账号级）
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15

# 登录限流（IP 级：window 秒内最多 max 次失败）
IP_RATE_LIMIT_MAX=20
IP_RATE_LIMIT_WINDOW_SECONDS=60
IP_RATE_LIMIT_BLOCK_SECONDS=300

# 数据库
# 默认使用 SQLite，相对 URL 会被归一化到 <repo>/python/backend/data/ 下
# 例：DATABASE_URL=sqlite:///./app.db  →  backend/data/app.db
# 生产环境建议改为 MySQL/PostgreSQL：mysql+pymysql://user:pwd@host:3306/db
DATABASE_URL=sqlite:///./app.db

# CORS 允许来源，多个用逗号分隔（部署时替换为前端域名）
CORS_ORIGINS=*

# ---------------- 邮件（SMTP，用于注册验证码等） ----------------
# QQ 邮箱示例：SMTP_HOST=smtp.qq.com  SMTP_PORT=465  SMTP_USE_SSL=true
# 163 邮箱示例：SMTP_HOST=smtp.163.com SMTP_PORT=465 SMTP_USE_SSL=true
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_TLS=false
# 发件邮箱（完整地址）与 SMTP 授权码；请勿提交真实值到仓库
SMTP_USER=your_qq_number@qq.com
SMTP_PASSWORD=please-set-me
SMTP_FROM_NAME=Docker Ops Console
# 发送方地址（默认与 SMTP_USER 一致，可覆盖为品牌邮箱）
SMTP_FROM_ADDR=

# 邮箱验证码配置
EMAIL_CODE_LENGTH=6
EMAIL_CODE_TTL_SECONDS=600
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_MAX_PER_HOUR=5
